// pos-backend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CAJERO
}

enum LossType {
  VENCIDO
  DANADO
  MERMA
  OTRO
}

enum ReturnType {
  VENCIDO
  DEFECTO_FABRICA
  MAL_ESTADO_LLEGADA
  OTRO
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CAJERO)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sales     Sale[]
  losses    ProductLoss[]
  returns   ProductReturn[]
}

model Product {
  id        Int      @id @default(autoincrement())
  name      String
  price     Float
  cost      Float    @default(0)
  stock     Int      @default(0)
  category  String?
  imageUrl  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  saleItems SaleItem[]
  losses    ProductLoss[]
  returns   ProductReturn[]
}

model Sale {
  id        Int        @id @default(autoincrement())
  total     Float
  userId    Int
  cancelled Boolean    @default(false)
  createdAt DateTime   @default(now())

  user      User       @relation(fields: [userId], references: [id])
  items     SaleItem[]
}

model SaleItem {
  id        Int     @id @default(autoincrement())
  quantity  Int
  unitPrice Float
  saleId    Int
  productId Int

  sale      Sale    @relation(fields: [saleId], references: [id])
  product   Product @relation(fields: [productId], references: [id])
}

model ProductLoss {
  id        Int      @id @default(autoincrement())
  productId Int
  quantity  Int
  reason    LossType
  notes     String?
  createdAt DateTime @default(now())
  userId    Int

  product   Product  @relation(fields: [productId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model ProductReturn {
  id        Int        @id @default(autoincrement())
  productId Int
  quantity  Int
  reason    ReturnType
  notes     String?
  supplier  String?
  createdAt DateTime   @default(now())
  userId    Int

  product   Product    @relation(fields: [productId], references: [id])
  user      User       @relation(fields: [userId], references: [id])
}

model Supplier {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  products  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

